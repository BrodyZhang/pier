# Database
DATABASE_URL=postgres://pier:pier@localhost:5432/pier

# Session
SESSION_SECRET=your-secret-key-here

# SMTP (optional - uses Resend API if host contains resend.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_api_key
SMTP_FROM=noreply@ailaopo.online

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL_BUILTIN=builtin-admin@example.com
CONTACT_EMAIL=contact@example.com

# Dev API (required for AI agent development)
DEV_API_KEY=your-dev-api-key

# Environment
NODE_ENV=production
APP_ENV=prod
PORT=3000
