<div class="card">
    <h1>个人设置</h1>
    <p style="color:#8c8caa;font-size:14px;margin-top:4px;"><%= user.email %></p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="error" data-toast="<%= error.replace(/'/g,'&#39;') %>" data-toast-type="error"><%= error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
<div class="success" data-toast="<%= success.replace(/'/g,'&#39;') %>" data-toast-type="success"><%= success %></div>
<% } %>

<div class="card">
    <h2>修改名称</h2>
    <form method="POST" action="/profile">
        <label for="name">显示名称</label>
        <input type="text" id="name" name="name" value="<%= user.name || '' %>" maxlength="50" placeholder="输入你的名称" required>
        <div style="margin-top:16px;">
            <button type="submit" class="btn btn-primary">保存</button>
        </div>
    </form>
</div>

<div class="card" style="border:1px solid rgba(211,47,47,0.2);">
    <h2 style="color:var(--red-700);">注销账号</h2>
    <p style="font-size:14px;color:var(--text-desc);margin-bottom:14px;">注销账号将永久删除你的所有数据和请求，此操作不可撤销。</p>

    <% if (typeof deleteSent !== 'undefined' && deleteSent) { %>
        <% if (typeof deleteError !== 'undefined' && deleteError) { %>
        <div class="error" data-toast="<%= deleteError.replace(/'/g,'&#39;') %>" data-toast-type="error"><%= deleteError %></div>
        <% } %>
        <p style="font-size:13px;color:#666;margin-bottom:10px;">验证码已发送到 <%= user.email %></p>
        <form method="POST" action="/profile/delete/confirm">
            <label for="deleteCode">输入验证码</label>
            <input type="text" id="deleteCode" name="code" maxlength="6" placeholder="6位验证码" required style="max-width:200px;">
            <div style="margin-top:12px;display:flex;gap:10px;">
                <button type="submit" class="btn btn-danger">确认注销</button>
                <a href="/profile" class="btn btn-outline">取消</a>
            </div>
        </form>
    <% } else { %>
        <form method="POST" action="/profile/delete/send-code">
            <button type="submit" class="btn btn-danger">发送验证码并注销</button>
        </form>
    <% } %>
</div>

<div class="card">
    <h2>账户信息</h2>
    <table>
        <tr><td data-label="邮箱">邮箱</td><td><%= user.email %></td></tr>
        <tr><td data-label="名称">显示名称</td><td><%= user.name || '未设置' %></td></tr>
        <tr><td data-label="角色">角色</td><td><%= user.role === 'admin' ? '管理员' : '用户' %></td></tr>
        <tr><td data-label="注册日期">注册日期</td><td><%= user.registration_date ? new Date(user.registration_date).toLocaleDateString('zh-CN') : '' %></td></tr>
    </table>
</div>
