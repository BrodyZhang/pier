<style>
.review-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
.review-action-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:4px; }
.review-label { font-size:12px; color:#b0b0c8; text-transform:uppercase; letter-spacing:0.5px; }
.review-value { margin-top:3px; color:#6c6c8a; }
.review-desc { margin-top:16px; background:rgba(233,30,99,0.04); padding:16px; border-radius:12px; border:1px solid rgba(233,30,99,0.08); white-space:pre-wrap; font-size:14px; line-height:1.7; color:#5c5c7a; }
.btn-full { width:100%; justify-content:center; display:flex; align-items:center; min-height:44px; }
@media (max-width:768px) {
    .review-grid, .review-action-grid { grid-template-columns:1fr; }
}
</style>
<div class="review-grid">
    <div class="card">
        <h2>请求详情</h2>
        <div style="margin-top:16px;">
            <div style="margin-bottom:14px;">
                <span class="review-label">名称</span>
                <div class="review-value" style="font-size:18px;font-weight:600;">
                    <%= agent.name %>
                    <% if (agent.version_number > 1) { %><span style="font-size:13px;color:#9c27b0;background:rgba(156,39,176,0.1);padding:2px 8px;border-radius:4px;margin-left:8px;">v<%= agent.version_number %></span><% } %>
                </div>
            </div>
            <div style="margin-bottom:14px;">
                <span class="review-label">用户</span>
                <div class="review-value" style="font-size:14px;"><%= agent.user_email %></div>
            </div>
            <div style="margin-bottom:14px;">
                <span class="review-label">提交时间</span>
                <div class="review-value" style="font-size:14px;"><%= new Date(agent.created_at).toLocaleString() %></div>
            </div>
            <% if (agent.parent_id) { %>
            <div style="margin-bottom:14px;">
                <span class="review-label">基于版本</span>
                <div class="review-value" style="font-size:14px;color:#9c27b0;">
                    v<%= agent.version_number - 1 %>
                    <% if (agent.parent_name) { %> — <%= agent.parent_name %><% } %>
                    <% if (agent.parent_slug) { %><a href="/agent/<%= agent.parent_slug %>" style="font-size:12px;color:#9c27b0;text-decoration:underline;">查看原版</a><% } %>
                </div>
            </div>
            <% } %>
            <div style="margin-bottom:14px;">
                <span class="review-label">状态</span>
                <div style="margin-top:6px;">
                    <span class="status status-<%= agent.status === 'pending_review' ? 'pending' : agent.status === 'in_development' ? 'dev' : agent.status === 'completed' ? 'done' : agent.status === 'dev_review' ? 'dev' : 'rejected' %>">
                        <% if (agent.status === 'pending_review') { %>待审核<% } else if (agent.status === 'in_development') { %>开发中<% } else if (agent.status === 'dev_review') { %>待验收<% } else if (agent.status === 'completed') { %>已完成<% } else { %>已拒绝<% } %>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <h2>描述内容</h2>
        <div class="review-desc"><%= agent.description %></div>
    </div>
</div>

<% if (agent.review_log && JSON.parse(agent.review_log).length > 0) { %>
<div class="card" style="margin-top:4px;">
    <h2>审核记录</h2>
    <div style="margin-top:12px;">
        <% JSON.parse(agent.review_log).forEach(function(entry) { %>
            <div style="background:rgba(255,255,255,0.5);border:1px solid rgba(233,30,99,0.08);border-radius:10px;padding:12px 14px;margin-bottom:8px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
                    <strong style="font-size:13px;">
                        <% if (entry.action === 'approved') { %><span style="color:#e91e63;">✓ 批准</span>
                        <% } else if (entry.action === 'rejected') { %><span style="color:#d32f2f;">✗ 拒绝</span>
                        <% } else if (entry.action === 'uploaded') { %><span style="color:#9c27b0;">↑ 上传</span>
                        <% } else if (entry.action === 'approved_dev') { %><span style="color:#e91e63;">✓ 验收通过</span>
                        <% } else if (entry.action === 'rejected_dev') { %><span style="color:#ff6f00;">↻ 退回修改</span>
                        <% } else { %><%= entry.action %><% } %>
                    </strong>
                    <span style="font-size:12px;color:#b0b0c8;"><%= new Date(entry.timestamp).toLocaleString() %></span>
                </div>
                <% if (entry.notes) { %>
                    <div style="font-size:13px;color:#c2185b;background:rgba(233,30,99,0.06);padding:6px 10px;border-radius:8px;margin-top:4px;"><%= entry.notes %></div>
                <% } %>
                <% if (entry.reason) { %>
                    <div style="font-size:13px;color:#d32f2f;background:rgba(211,47,47,0.06);padding:6px 10px;border-radius:8px;margin-top:4px;"><%= entry.reason %></div>
                <% } %>
                <% if (entry.comments) { %>
                    <div style="font-size:13px;color:#e65100;background:rgba(255,111,0,0.06);padding:6px 10px;border-radius:8px;margin-top:4px;"><%= entry.comments %></div>
                <% } %>
            </div>
        <% }) %>
    </div>
</div>
<% } %>

<% if (agent.status === 'pending_review') { %>
<div class="review-action-grid">
    <div class="card" style="border-left:3px solid #e91e63;">
        <h2 style="color:#e91e63;">批准</h2>
        <p style="font-size:14px;color:#b0b0c8;margin-bottom:16px;">审批通过后，AI 将根据审核信息进行开发。</p>
        <form method="POST" action="/admin/requests/<%= agent.id %>/approve">
            <label>审核信息（AI 开发优先级规则）</label>
            <textarea name="review_notes" rows="5" maxlength="200" placeholder="请填写审核信息（最多200字）..." style="min-height:100px;"><%= agent.review_notes || '' %></textarea>
            <button type="submit" class="btn btn-success btn-full">批准并开始开发</button>
        </form>
    </div>

    <div class="card" style="border-left:3px solid #d32f2f;">
        <h2 style="color:#d32f2f;">拒绝</h2>
        <form method="POST" action="/admin/requests/<%= agent.id %>/reject">
            <label>拒绝原因</label>
            <textarea name="reason" rows="5" required maxlength="200" placeholder="请填写拒绝原因（最多200字）"></textarea>
            <button type="submit" class="btn btn-danger btn-full">拒绝请求</button>
        </form>
    </div>
</div>
<% } %>

<% if (agent.status === 'in_development') { %>
<div class="card" style="border-left:3px solid #9c27b0;margin-top:4px;">
    <h2>上传 HTML</h2>
    <div style="margin-top:16px;">
        <% if (agent.review_notes) { %>
        <div style="background:rgba(233,30,99,0.06);border:1px solid rgba(233,30,99,0.12);border-radius:8px;padding:10px 14px;margin-bottom:14px;">
            <div style="font-size:12px;color:#b0b0c8;margin-bottom:3px;">审核说明</div>
            <div style="font-size:13px;color:#e91e63;"><%= agent.review_notes %></div>
        </div>
        <% } %>
        <% if (agent.review_comments) { %>
        <div style="background:rgba(255,111,0,0.06);border:1px solid rgba(255,111,0,0.12);border-radius:8px;padding:10px 14px;margin-bottom:14px;">
            <div style="font-size:12px;color:#b0b0c8;margin-bottom:3px;">上次退回意见</div>
            <div style="font-size:13px;color:#e65100;"><%= agent.review_comments %></div>
        </div>
        <% } %>
        <form method="POST" action="/admin/requests/<%= agent.id %>/upload" enctype="multipart/form-data">
            <label>HTML 文件</label>
            <input type="file" name="html" accept=".html" required style="padding:10px;">
            <p style="font-size:13px;color:#b0b0c8;margin-top:8px;">上传制作完成的告白页 HTML 文件。</p>
            <button type="submit" class="btn btn-primary" style="margin-top:14px;">上传并标记完成</button>
        </form>
    </div>
</div>
<% } %>

<% if (agent.status === 'dev_review') { %>
<div class="card" style="margin-top:4px;">
    <h2>待验收</h2>
    <div style="margin-top:16px;">
        <% if (agent.review_notes) { %>
        <div style="background:rgba(233,30,99,0.06);border:1px solid rgba(233,30,99,0.12);border-radius:8px;padding:10px 14px;margin-bottom:14px;">
            <div style="font-size:12px;color:#b0b0c8;margin-bottom:3px;">原始审核说明</div>
            <div style="font-size:13px;color:#e91e63;"><%= agent.review_notes %></div>
        </div>
        <% } %>
        <div class="review-action-grid">
            <form method="POST" action="/admin/requests/<%= agent.id %>/approve-dev">
                <button type="submit" class="btn btn-success btn-full">✓ 验收通过</button>
            </form>
            <form method="POST" action="/admin/requests/<%= agent.id %>/reject-dev">
                <label>修改意见（退回后 AI 将根据此意见修改）</label>
                <textarea name="review_comments" rows="5" required maxlength="200" placeholder="请详细描述需要修改的地方（最多200字）..." style="min-height:100px;"><%= agent.review_comments || '' %></textarea>
                <button type="submit" class="btn btn-danger btn-full" style="margin-top:10px;">↻ 退回修改</button>
            </form>
        </div>
        <div style="margin-top:14px;">
            <a href="/agent/<%= agent.unique_slug %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="justify-content:center;">预览最新版本</a>
        </div>
    </div>
</div>
<% } %>

<% if (agent.status === 'completed' && agent.unique_slug) { %>
<div class="card" style="border-left:3px solid #e91e63;margin-top:4px;">
    <h2 style="color:#e91e63;">已完成</h2>
    <div style="margin-top:16px;">
        <div class="flex flex-wrap flex-between flex-center gap">
            <div>
                <p style="font-size:14px;color:#6c6c8a;">短链接：<code><%= agent.unique_slug %></code></p>
                <p style="font-size:13px;color:#b0b0c8;margin-top:4px;">
                    推荐状态：<%= agent.showcased ? '已推荐到首页' : '未推荐' %>
                </p>
            </div>
            <div class="flex flex-wrap gap-sm">
                <a href="/agent/<%= agent.unique_slug %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">查看告白页</a>
                <form method="POST" action="/admin/requests/<%= agent.id %>/toggle-showcase" style="display:inline;">
                    <button type="submit" class="btn btn-sm" style="background:<%= agent.showcased ? 'rgba(233,30,99,0.12)' : 'rgba(255,215,0,0.12)' %>;color:<%= agent.showcased ? '#c2185b' : '#b8860b' %>;border:1px solid <%= agent.showcased ? 'rgba(233,30,99,0.2)' : 'rgba(255,215,0,0.3)' %>;padding:8px 18px;border-radius:10px;cursor:pointer;font-size:14px;">
                        <%= agent.showcased ? '取消推荐' : '推荐到首页' %>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
<% } %>

<% if (agent.status === 'rejected') { %>
<div class="card" style="border-left:3px solid #d32f2f;margin-top:4px;">
    <h2 style="color:#d32f2f;">已拒绝</h2>
    <p style="font-size:14px;color:#6c6c8a;margin-top:8px;">拒绝原因：<span style="color:#d32f2f;"><%= agent.rejection_reason %></span></p>
</div>
<% } %>