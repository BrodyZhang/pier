<div class="card">
    <h1>🛠️ 告白请求管理</h1>
    <p style="margin-top:10px;font-size:14px;color:#666;">
        AI 开发接口：<code style="background:#f0f0f0;padding:2px 6px;border-radius:4px;">GET /api/dev/agents</code>
        — 返回待开发列表（JSON），AI 取走后生成 HTML 并上传。
    </p>
</div>

<div class="card">
    <h2>待审核</h2>
    <% if (pending.length === 0) { %>
        <p style="color:#666;">暂无待审核请求。</p>
    <% } else { %>
        <table>
            <tr><th>名称</th><th>用户</th><th>描述</th><th>日期</th><th></th></tr>
            <% pending.forEach(function(a) { %>
                <tr>
                    <td><%= a.name %></td>
                    <td><%= a.user_email %></td>
                    <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= a.description %></td>
                    <td style="font-size:14px;color:#666;"><%= new Date(a.created_at).toLocaleDateString() %></td>
                    <td><a href="/admin/requests/<%= a.id %>" class="btn btn-primary btn-sm">审核</a></td>
                </tr>
            <% }) %>
        </table>
    <% } %>
</div>

<div class="card">
    <h2>开发中</h2>
    <% if (dev.length === 0) { %>
        <p style="color:#666;">暂无开发中的请求。</p>
    <% } else { %>
        <table>
            <tr><th>名称</th><th>用户</th><th>日期</th><th></th></tr>
            <% dev.forEach(function(a) { %>
                <tr>
                    <td><%= a.name %></td>
                    <td><%= a.user_email %></td>
                    <td style="font-size:14px;color:#666;"><%= new Date(a.created_at).toLocaleDateString() %></td>
                    <td>
                        <a href="/admin/requests/<%= a.id %>" class="btn btn-primary btn-sm">管理</a>
                        <% if (a.unique_slug) { %>
                            <a href="/agent/<%= a.unique_slug %>" class="btn btn-outline btn-sm" style="margin-left:5px;">查看</a>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </table>
    <% } %>
</div>

<div class="card">
    <h2>已完成</h2>
    <% if (completed.length === 0) { %>
        <p style="color:#666;">暂无完成的请求。</p>
    <% } else { %>
        <table>
            <tr><th>名称</th><th>用户</th><th>短链接</th><th></th></tr>
            <% completed.forEach(function(a) { %>
                <tr>
                    <td><%= a.name %></td>
                    <td><%= a.user_email %></td>
                    <td><code><%= a.unique_slug %></code></td>
                    <td><a href="/agent/<%= a.unique_slug %>" class="btn btn-outline btn-sm">查看</a></td>
                </tr>
            <% }) %>
        </table>
    <% } %>
</div>

<div class="card">
    <h2>已拒绝</h2>
    <% if (rejected.length === 0) { %>
        <p style="color:#666;">暂无被拒绝的请求。</p>
    <% } else { %>
        <table>
            <tr><th>名称</th><th>用户</th><th>原因</th><th></th></tr>
            <% rejected.forEach(function(a) { %>
                <tr>
                    <td><%= a.name %></td>
                    <td><%= a.user_email %></td>
                    <td style="color:#e74c3c;"><%= a.rejection_reason %></td>
                    <td><a href="/admin/requests/<%= a.id %>" class="btn btn-outline btn-sm">查看</a></td>
                </tr>
            <% }) %>
        </table>
    <% } %>
</div>
