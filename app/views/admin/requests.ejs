<style>
.bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 14px;
}
.bento-card {
    background: var(--surface-card);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-radius: var(--radius-card-sm);
    border: 1px solid var(--border-card);
    padding: 0;
    box-shadow: var(--shadow-card);
    transition: transform var(--ease-smooth), box-shadow var(--ease-smooth);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
}
.bento-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
}
.bento-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
}
.bento-card.status-pending::before { background: var(--orange-500); }
.bento-card.status-dev::before { background: var(--purple-500); }
.bento-card.status-done::before { background: var(--green-600); }
.bento-card.status-rejected::before { background: #f44336; }
.bento-card.status-review::before { background: var(--pink-500); }

.bento-card-header {
    padding: 16px 16px 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
}
.bento-card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-secondary);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.bento-card-meta {
    padding: 0 16px;
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
}
.bento-card-meta .email { font-size: 12px; color: var(--text-muted); }
.bento-card-meta .date { font-size: 11px; color: var(--text-muted); margin-left: auto; }
.bento-card-desc {
    padding: 10px 16px 0;
    font-size: 13px;
    color: var(--text-desc);
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}
.bento-card-notes {
    padding: 0 16px;
    margin-top: 8px;
}
.bento-card-notes .note {
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 8px;
    margin-bottom: 4px;
}
.bento-card-notes .note-green { background: rgba(76,175,80,0.06); color: var(--green-800); }
.bento-card-notes .note-orange { background: rgba(255,152,0,0.06); color: var(--orange-800); }
.bento-card-notes .note-purple { background: rgba(156,39,176,0.06); color: var(--purple-700); }

.bento-card-actions {
    padding: 12px 16px;
    margin-top: auto;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
}
.bento-card-actions .btn-sm { font-size: 12px; padding: 5px 12px; min-height: 32px; }
.bento-card-actions .btn-sm input,
.bento-card-actions .btn-sm textarea { font-size: 12px; padding: 6px 10px; min-height: 32px; }
.bento-card-actions input[type="text"] {
    width: 130px;
    padding: 6px 10px;
    font-size: 12px;
    border-radius: 8px;
    border: 1.5px solid var(--border-input);
    background: var(--surface-input);
    color: var(--text-primary);
    transition: border-color var(--ease-smooth);
}
.bento-card-actions input[type="text"]:focus { outline: none; border-color: var(--pink-500); }
.bento-card-actions textarea {
    width: 100%;
    padding: 6px 10px;
    font-size: 12px;
    border-radius: 8px;
    border: 1.5px solid var(--border-input);
    background: var(--surface-input);
    color: var(--text-primary);
    resize: none;
    min-height: 32px;
}
.bento-card-actions textarea:focus { outline: none; border-color: var(--pink-500); }

@media (min-width: 769px) {
    .bento-card.bento-wide { grid-column: span 2; }
}
@media (max-width: 768px) {
    .bento-grid { grid-template-columns: 1fr; gap: 12px; }
    .bento-card-header { padding: 14px 14px 0; }
    .bento-card-meta, .bento-card-desc, .bento-card-notes { padding-left: 14px; padding-right: 14px; }
    .bento-card-actions { padding: 10px 14px; flex-direction: column; align-items: stretch; }
    .bento-card-actions input[type="text"] { width: 100%; }
    .bento-card-actions form { width: 100%; }
    .bento-card-actions .btn-sm { width: 100%; justify-content: center; }
}
.bento-card-actions .btn-rename { background:rgba(255,255,255,0.5); color:var(--text-secondary); border:1px solid var(--border-input); padding:5px 10px; border-radius:8px; cursor:pointer; font-size:12px; }
@media (prefers-color-scheme: dark) {
    .bento-card { background: var(--surface-card); border-color: var(--border-card); }
    .bento-card-actions .btn-rename { background:rgba(40,20,30,0.6); color:var(--text-secondary); border-color:rgba(233,30,99,0.3); }
}
</style>

<div class="card" style="padding:20px 28px;">
    <div class="flex flex-wrap flex-between flex-center" style="gap:12px;">
        <h1>管理后台</h1>
    </div>
    <div class="tabs" id="tabs" style="margin-top:16px;">
        <button class="tab-btn active" data-tab="all">全部 <span class="badge-count badge-done"><%= pending.length + dev.length + devReview.length + completed.length + rejected.length %></span></button>
        <button class="tab-btn" data-tab="pending">待审核 <span class="badge-count badge-pending"><%= pending.length %></span></button>
        <button class="tab-btn" data-tab="dev">开发中 <span class="badge-count badge-dev"><%= dev.length %></span></button>
        <button class="tab-btn" data-tab="devReview">待验收 <span class="badge-count badge-review"><%= devReview.length %></span></button>
        <button class="tab-btn" data-tab="completed">已完成 <span class="badge-count badge-done"><%= completed.length %></span></button>
        <button class="tab-btn" data-tab="rejected">已拒绝 <span class="badge-count badge-done"><%= rejected.length %></span></button>
    </div>
</div>

<% function statusClass(s) {
    if (s === 'pending_review') return 'pending';
    if (s === 'in_development') return 'dev';
    if (s === 'dev_review') return 'review';
    if (s === 'completed') return 'done';
    return 'rejected';
}
function statusLabel(s) {
    if (s === 'pending_review') return '待审核';
    if (s === 'in_development') return '开发中';
    if (s === 'dev_review') return '待验收';
    if (s === 'completed') return '已完成';
    return '已拒绝';
}
%>

<% var tabs = { all: [...pending, ...dev, ...devReview, ...completed, ...rejected], pending: pending, dev: dev, devReview: devReview, completed: completed, rejected: rejected }; %>
<% Object.keys(tabs).forEach(function(tab) { %>
<div id="<%= tab %>" class="tab-content<%= tab === 'all' ? ' active' : '' %>">
    <div class="card" style="padding:16px;">
        <% var items = tabs[tab]; %>
        <% if (items.length === 0) { %>
            <div class="empty-state">
                <svg width="60" height="60" viewBox="0 0 80 80" fill="none" style="margin-bottom:8px;">
                    <path d="M40 72C36 60 16 48 16 32C16 22 24 14 34 14C40 14 44 17 46 20C48 17 53 14 58 14C68 14 74 22 74 32C74 48 56 60 40 72Z" fill="url(#hG<%= tab %>)" opacity="0.5"/>
                    <defs><linearGradient id="hG<%= tab %>" x1="20" y1="18" x2="60" y2="70"><stop stop-color="#ff6b9d"/><stop offset="1" stop-color="#c2185b"/></linearGradient></defs>
                </svg>
                <p style="font-size:14px;">暂无请求</p>
            </div>
        <% } else { %>
            <div class="bento-grid">
            <% items.forEach(function(a) { %>
                <% var sc = statusClass(a.status); %>
                <% var needsWide = (a.status === 'pending_review' || a.status === 'dev_review' || a.review_notes || a.review_comments); %>
                <div class="bento-card status-<%= sc %><%= needsWide ? ' bento-wide' : '' %>">
                    <div class="bento-card-header">
                        <span class="bento-card-title" title="<%= a.name %>"><%= a.name %></span>
                        <span class="status status-<%= sc %>" style="flex-shrink:0;"><%= statusLabel(a.status) %></span>
                    </div>
                    <div class="bento-card-meta">
                        <span class="email"><%= a.user_email %></span>
                        <% if (a.version_number > 1) { %><span style="background:rgba(156,39,176,0.1);color:var(--purple-500);padding:1px 6px;border-radius:3px;font-size:10px;">v<%= a.version_number %></span><% } %>
                        <% if (a.parent_id) { %><span style="color:var(--text-muted);font-size:10px;">↳ v<%= a.version_number - 1 %></span><% } %>
                        <% if (a.is_public) { %><span style="color:var(--green-800);font-size:10px;background:rgba(76,175,80,0.1);padding:1px 6px;border-radius:3px;">🌐 公开</span><% } else { %><span style="color:#e65100;font-size:10px;background:rgba(255,152,0,0.1);padding:1px 6px;border-radius:3px;">🔒 私密</span><% } %>
                        <span class="date"><%= new Date(a.created_at).toLocaleDateString() %></span>
                    </div>
                    <div class="bento-card-desc"><%= a.description %></div>
                    <div class="bento-card-notes">
                        <% if (a.review_notes) { %><div class="note note-green">📋 <%= a.review_notes %></div><% } %>
                        <% if (a.review_comments) { %><div class="note note-orange">💬 <%= a.review_comments %></div><% } %>
                        <% if (a.parent_id && a.parent_name) { %><div class="note note-purple">↳ 基于: <%= a.parent_name %></div><% } %>
                    </div>
                    <div class="bento-card-actions">
                        <% if (a.status === 'pending_review') { %>
                            <form method="POST" action="/admin/requests/<%= a.id %>/approve" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                <input type="text" name="review_notes" placeholder="审核说明" required maxlength="200">
                                <button type="submit" class="btn btn-success btn-sm">批准</button>
                            </form>
                            <form method="POST" action="/admin/requests/<%= a.id %>/reject" style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                <input type="text" name="reason" placeholder="拒绝原因" required maxlength="200">
                                <button type="submit" class="btn btn-danger btn-sm">拒绝</button>
                            </form>
                        <% } else if (a.status === 'in_development') { %>
                            <% if (a.unique_slug) { %><a href="/agent/<%= a.unique_slug %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">预览</a><% } %>
                        <% } else if (a.status === 'dev_review') { %>
                            <% if (a.unique_slug) { %><a href="/agent/<%= a.unique_slug %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">预览</a><% } %>
                            <form method="POST" action="/admin/requests/<%= a.id %>/approve-dev" style="display:inline;"><button type="submit" class="btn btn-success btn-sm">通过</button></form>
                            <form method="POST" action="/admin/requests/<%= a.id %>/reject-dev" style="flex:1;display:flex;align-items:center;gap:6px;">
                                <textarea name="review_comments" rows="1" required placeholder="修改意见..." maxlength="200"><%= a.review_comments || '' %></textarea>
                                <button type="submit" class="btn btn-danger btn-sm">退回</button>
                            </form>
                        <% } else if (a.status === 'completed') { %>
                            <% if (a.unique_slug) { %>
                                <a href="/agent/<%= a.unique_slug %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">查看</a>
                                <% if (a.is_public) { %>
                                <form method="POST" action="/admin/requests/<%= a.id %>/toggle-showcase" style="display:inline;">
                                    <button type="submit" class="btn btn-sm" style="background:<%= a.showcased ? 'rgba(233,30,99,0.12)' : 'rgba(255,215,0,0.12)' %>;color:<%= a.showcased ? 'var(--pink-700)' : 'var(--gold)' %>;border:1px solid <%= a.showcased ? 'rgba(233,30,99,0.2)' : 'var(--gold-border)' %>;padding:5px 12px;border-radius:8px;cursor:pointer;font-size:12px;">
                                        <%= a.showcased ? '已推荐' : '推荐到首页' %>
                                    </button>
                                </form>
                                <% } else { %>
                                <span style="font-size:11px;color:#e65100;background:rgba(255,152,0,0.1);padding:2px 8px;border-radius:3px;">🔒 私密 · 不可推荐</span>
                                <% } %>
                            <% } %>
                        <% } else if (a.status === 'rejected') { %>
                            <span class="text-sm" style="color:var(--red-700);padding:2px 0;"><%= a.rejection_reason %></span>
                        <% } %>
                        <form method="POST" action="/admin/requests/<%= a.id %>/rename" style="display:inline;">
                            <button type="button" class="btn btn-sm btn-rename" onclick="var n=prompt('输入新名称','<%= a.name.replace(/'/g,"\\'") %>');if(n&&n.trim()){this.closest('form').querySelector('input').value=n.trim();this.closest('form').submit()}">改名</button>
                            <input type="hidden" name="name" value="">
                        </form>
                        <form method="POST" action="/admin/requests/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('确定删除？');">
                            <button type="submit" class="btn btn-sm" style="background:rgba(233,30,99,0.08);color:var(--pink-700);border:1px solid rgba(233,30,99,0.15);padding:5px 10px;border-radius:8px;cursor:pointer;font-size:12px;">删除</button>
                        </form>
                    </div>
                </div>
            <% }) %>
            </div>
        <% } %>
    </div>
</div>
<% }) %>

<script>
(function() {
    var tabs = document.querySelectorAll('.tab-btn');
    tabs.forEach(function(btn) {
        btn.addEventListener('click', function() {
            tabs.forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
            var target = document.getElementById(btn.getAttribute('data-tab'));
            if (target) target.classList.add('active');
        });
    });
})();
</script>