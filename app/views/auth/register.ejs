<div class="card" style="max-width:440px;margin:40px auto;">
    <h1>注册</h1>
    <div class="disclaimer">
        本项目为学习项目，数据可能随时被清除。需年满18岁。
    </div>
    <% if (typeof remainingSlots !== 'undefined') { %>
        <p style="text-align:center;font-size:14px;color:#b0b0c8;margin-bottom:15px;">
            今日剩余注册名额：<strong style="color:#e91e63;"><%= remainingSlots %></strong> / 20
        </p>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="error"><%= error %></div>
    <% } %>
    <% if (sent) { %>
        <div class="success">验证码已发送至 <strong><%= email %></strong></div>
        <form method="POST" action="/auth/register/verify">
            <input type="hidden" name="email" value="<%= email %>">
            <label>验证码</label>
            <input type="text" name="code" maxlength="6" required placeholder="输入6位验证码">
            <button type="submit" class="btn btn-primary" style="margin-top:20px;width:100%;justify-content:center;">验证并注册</button>
        </form>
        <form method="POST" id="resendForm" style="margin-top:12px;text-align:center;">
            <input type="hidden" name="email" value="<%= email %>">
            <button type="submit" id="resendBtn" class="btn btn-outline btn-sm" disabled>重新发送（<span id="cooldown">60</span>）</button>
        </form>
        <script>
        (function(){
            var remaining = 60; var btn = document.getElementById('resendBtn'); var cd = document.getElementById('cooldown');
            function tick() { remaining--; if (cd) cd.textContent = remaining; if (remaining <= 0) { if (btn) { btn.disabled = false; btn.textContent = '重新发送'; } } else { setTimeout(tick, 1000); } }
            if (remaining > 0) setTimeout(tick, 1000);
        })();
        </script>
    <% } else { %>
        <form method="POST">
            <label>邮箱</label>
            <input type="email" name="email" required placeholder="you@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>">
            <button type="submit" class="btn btn-primary" style="margin-top:20px;width:100%;justify-content:center;">发送验证码</button>
        </form>
        <p style="margin-top:18px;color:#b0b0c8;font-size:14px;">已有账号？<a href="/auth/login" style="color:#e91e63;text-decoration:none;">立即登录</a></p>
    <% } %>
</div>
