<div class="card" style="max-width:450px;margin:40px auto;">
    <h1>注册</h1>
    <div class="disclaimer">
        本项目为学习项目，数据可能随时被清除。需年满18岁。
    </div>
    <% if (typeof remainingSlots !== 'undefined') { %>
        <p style="text-align:center;font-size:14px;color:#666;margin-bottom:15px;">
            今日剩余注册名额：<strong style="color:#667eea;"><%= remainingSlots %></strong> / 100
        </p>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
        <div class="error"><%= error %></div>
    <% } %>
    <% if (sent) { %>
        <div class="success">验证码已发送至 <strong><%= email %></strong>（开发模式请查看控制台输出）</div>
        <form method="POST" action="/auth/register/verify">
            <input type="hidden" name="email" value="<%= email %>">
            <label>验证码</label>
            <input type="text" name="code" maxlength="6" required placeholder="输入6位验证码">
            <button type="submit" class="btn btn-primary" style="margin-top:20px;">验证并注册</button>
        </form>
    <% } else { %>
        <form method="POST">
            <label>邮箱</label>
            <input type="email" name="email" required placeholder="you@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>">
            <button type="submit" class="btn btn-primary" style="margin-top:20px;">发送验证码</button>
        </form>
        <p style="margin-top:20px;color:#666;">已有账号？<a href="/auth/login">立即登录</a></p>
    <% } %>
</div>
