<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <title><%= typeof title !== 'undefined' ? title : 'Pier' %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --pink-50: #fff0f5;
            --pink-100: #ffe4ec;
            --pink-200: #ffd6e0;
            --pink-500: #ff6b9d;
            --pink-700: #c2185b;
            --pink-800: #e91e63;
            --red-400: #ff5252;
            --red-700: #d32f2f;
            --red-800: #c62828;
            --green-600: #4caf50;
            --green-800: #2e7d32;
            --orange-500: #ff9800;
            --orange-800: #e65100;
            --purple-500: #9c27b0;
            --purple-700: #7b1fa2;
            --gold: #b8860b;
            --gold-light: rgba(255,215,0,0.12);
            --gold-border: rgba(255,215,0,0.3);
            --text-primary: #4a4a6a;
            --text-secondary: #5c5c7a;
            --text-tertiary: #6c6c8a;
            --text-desc: #8c8caa;
            --text-muted: #b0b0c8;
            --text-white: #fff;
            --body-bg-start: #fff0f5;
            --body-bg-mid: #ffe4ec;
            --body-bg-end: #ffd6e0;
            --surface-card: rgba(255,255,255,0.85);
            --surface-nav: rgba(255,255,255,0.75);
            --surface-input: rgba(255,255,255,0.8);
            --surface-tab: rgba(255,255,255,0.6);
            --surface-list: rgba(255,255,255,0.75);
            --surface-stat: rgba(255,255,255,0.7);
            --surface-btn-outline: rgba(255,255,255,0.7);
            --glass-blur: 12px;
            --glass-blur-nav: 20px;
            --glass-blur-list: 8px;
            --border-card: rgba(255,182,193,0.25);
            --border-card-hover: rgba(255,182,193,0.2);
            --border-subtle: rgba(233,30,99,0.08);
            --border-input: rgba(233,30,99,0.15);
            --border-nav: rgba(233,30,99,0.08);
            --border-list: rgba(255,182,193,0.2);
            --border-stat: rgba(233,30,99,0.08);
            --border-btn-outline: rgba(233,30,99,0.2);
            --shadow-card: 0 4px 24px rgba(233,30,99,0.06);
            --shadow-card-hover: 0 8px 32px rgba(233,30,99,0.12);
            --shadow-list: 0 4px 16px rgba(233,30,99,0.08);
            --shadow-nav: 0 8px 24px rgba(0,0,0,0.06);
            --shadow-btn: 0 4px 20px rgba(255,107,157,0.4);
            --shadow-btn-danger: 0 4px 20px rgba(255,82,82,0.4);
            --shadow-btn-success: 0 4px 20px rgba(233,30,99,0.4);
            --radius-card: 20px;
            --radius-card-sm: 14px;
            --radius-btn: 12px;
            --radius-btn-sm: 8px;
            --radius-sm: 6px;
            --radius-pill: 20px;
            --brand-gradient: linear-gradient(135deg, #ff6b9d, #c2185b);
            --btn-primary-bg: linear-gradient(135deg, #ff6b9d, #c2185b);
            --btn-success-bg: linear-gradient(135deg, #ff6b9d, #e91e63);
            --btn-danger-bg: linear-gradient(135deg, #ff5252, #d32f2f);
            --ease-smooth: 0.2s;
            --toast-bg-error: #d32f2f;
            --toast-bg-success: #2e7d32;
            --toast-bg-info: #7b1fa2;
            --nav-email-maxw: 180px;
            --container-maxw: 1000px;
        }
        @media (prefers-color-scheme: dark) {
            :root {
                --pink-50: #1a0a12;
                --pink-100: #24101a;
                --pink-200: #2e1520;
                --text-primary: #e0d0d8;
                --text-secondary: #c8b8c0;
                --text-tertiary: #9a8a92;
                --text-desc: #8a7a82;
                --text-muted: #6a5a62;
                --body-bg-start: #1a0a12;
                --body-bg-mid: #24101a;
                --body-bg-end: #2e1520;
                --surface-card: rgba(35,15,25,0.88);
                --surface-nav: rgba(30,12,20,0.88);
                --surface-input: rgba(40,20,30,0.85);
                --surface-tab: rgba(40,20,30,0.6);
                --surface-list: rgba(35,15,25,0.85);
                --surface-stat: rgba(35,15,25,0.7);
                --surface-btn-outline: rgba(40,20,30,0.7);
                --border-card: rgba(255,182,193,0.08);
                --border-card-hover: rgba(255,182,193,0.12);
                --border-subtle: rgba(233,30,99,0.15);
                --border-input: rgba(233,30,99,0.25);
                --border-nav: rgba(233,30,99,0.15);
                --border-list: rgba(255,182,193,0.1);
                --border-stat: rgba(233,30,99,0.12);
                --border-btn-outline: rgba(233,30,99,0.25);
                --shadow-card: 0 4px 24px rgba(0,0,0,0.4);
                --shadow-card-hover: 0 8px 32px rgba(0,0,0,0.5);
                --shadow-list: 0 4px 16px rgba(0,0,0,0.3);
                --shadow-nav: 0 8px 24px rgba(0,0,0,0.4);
                --toast-bg-error: #c62828;
                --toast-bg-success: #2e7d32;
                --toast-bg-info: #6a1b9a;
            }
        }
        body {
            font-family: -apple-system, 'Microsoft YaHei', 'PingFang SC', sans-serif;
            background: linear-gradient(180deg, var(--body-bg-start) 0%, var(--body-bg-mid) 25%, var(--body-bg-end) 50%, var(--body-bg-mid) 75%, var(--body-bg-start) 100%);
            min-height: 100vh;
            color: var(--text-primary);
        }
        .container { max-width: var(--container-maxw); margin: 0 auto; padding: 20px; position: relative; }
        .card {
            background: var(--surface-card);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--border-card);
            border-radius: var(--radius-card);
            padding: 28px;
            margin: 20px 0;
            box-shadow: var(--shadow-card);
            transition: transform var(--ease-smooth), box-shadow var(--ease-smooth);
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-card-hover);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 12px 24px;
            border-radius: var(--radius-btn);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all 0.25s;
            min-height: 44px;
        }
        .btn-primary {
            background: var(--btn-primary-bg);
            color: var(--text-white);
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: var(--shadow-btn); }
        .btn-success {
            background: var(--btn-success-bg);
            color: var(--text-white);
        }
        .btn-success:hover { transform: translateY(-1px); box-shadow: var(--shadow-btn-success); }
        .btn-danger {
            background: var(--btn-danger-bg);
            color: var(--text-white);
        }
        .btn-danger:hover { transform: translateY(-1px); box-shadow: var(--shadow-btn-danger); }
        .btn-outline {
            background: var(--surface-btn-outline);
            border: 1.5px solid var(--border-btn-outline);
            color: var(--pink-700);
        }
        .btn-outline:hover { border-color: var(--pink-500); background: rgba(255,107,157,0.08); }
        .btn-sm { padding: 6px 16px; font-size: 13px; border-radius: var(--radius-btn-sm); }
        .error { color: var(--red-700); background: rgba(255,82,82,0.08); padding: 14px 18px; border-radius: var(--radius-btn); margin: 12px 0; border-left: 3px solid var(--red-400); }
        .success { color: var(--green-800); background: rgba(76,175,80,0.08); padding: 14px 18px; border-radius: var(--radius-btn); margin: 12px 0; border-left: 3px solid var(--green-600); }
        h1 { font-size: 26px; font-weight: 700; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        h2 { font-size: 18px; font-weight: 600; color: var(--text-secondary); margin-bottom: 16px; }
        label { display: block; margin: 14px 0 6px; font-weight: 500; color: var(--text-tertiary); font-size: 14px; }
        input, textarea, select {
            width: 100%;
            padding: 14px 14px;
            background: var(--surface-input);
            border: 1.5px solid var(--border-input);
            border-radius: var(--radius-btn);
            font-size: 16px;
            color: var(--text-primary);
            transition: border-color var(--ease-smooth), box-shadow var(--ease-smooth);
            font-family: inherit;
        }
        input:focus, textarea:focus, select:focus { outline: none; border-color: var(--pink-500); box-shadow: 0 0 0 3px rgba(255,107,157,0.15); }
        textarea { resize: vertical; min-height: 100px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 14px 12px; border-bottom: 1px solid var(--border-subtle); }
        th { font-weight: 600; color: var(--text-muted); font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
        td { color: var(--text-secondary); font-size: 14px; }
        tr:hover td { background: rgba(255,107,157,0.03); }
        .status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: var(--radius-pill);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }
        .status-pending { background: rgba(255,152,0,0.12); color: var(--orange-800); }
        .status-pending::before { background: var(--orange-500); }
        .status-dev { background: rgba(156,39,176,0.1); color: var(--purple-700); }
        .status-dev::before { background: var(--purple-500); }
        .status-done { background: rgba(76,175,80,0.1); color: var(--green-800); }
        .status-done::before { background: var(--green-600); }
        .status-rejected { background: rgba(244,67,54,0.1); color: var(--red-800); }
        .status-rejected::before { background: #f44336; }
        .nav {
            background: var(--surface-nav);
            backdrop-filter: blur(var(--glass-blur-nav));
            -webkit-backdrop-filter: blur(var(--glass-blur-nav));
            border-bottom: 1px solid var(--border-nav);
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
        }
        .nav .nav-links { display: flex; align-items: center; gap: 6px; }
            .nav-email { display: inline-block; max-width: var(--nav-email-maxw); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; color: var(--text-muted); }
            a.nav-email { color: var(--text-muted); text-decoration: none; border-bottom: 1px dashed rgba(176,176,200,0.3); }
            a.nav-email:hover { color: var(--pink-500); border-bottom-color: var(--pink-500); }
        .nav a { color: var(--text-tertiary); text-decoration: none; font-size: 14px; transition: color var(--ease-smooth); }
        .nav a:hover { color: var(--pink-500); }
        .nav .brand { font-weight: 700; font-size: 18px; background: var(--brand-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-right: auto; }
        .nav form { display: inline; }
        .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 6px; color: var(--text-tertiary); font-size: 22px; }
        .watermark {
            text-align: center;
            padding: 20px 0;
            font-size: 12px;
            color: #aaa;
            letter-spacing: 0.5px;
        }
        .disclaimer {
            background: rgba(255,152,0,0.06);
            border: 1px solid rgba(255,152,0,0.15);
            padding: 12px 16px;
            border-radius: var(--radius-btn);
            margin: 16px 0;
            font-size: 13px;
            color: var(--orange-800);
        }
        code {
            background: rgba(255,107,157,0.08);
            padding: 2px 8px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            color: var(--pink-700);
        }
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-muted);
        }
        .empty-state p { font-size: 15px; margin-top: 8px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: var(--surface-stat);
            border: 1px solid var(--border-stat);
            border-radius: var(--radius-card-sm);
            padding: 16px;
            text-align: center;
        }
        .stat-card .num { font-size: 28px; font-weight: 700; }
        .stat-card .label { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 0;
            background: var(--surface-tab);
            border-radius: var(--radius-card-sm);
            padding: 4px;
            overflow-x: auto;
        }
        .tab-btn {
            padding: 8px 18px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: all var(--ease-smooth);
        }
        .tab-btn:hover { color: var(--text-tertiary); }
        .tab-btn.active { background: rgba(255,107,157,0.15); color: var(--pink-700); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .badge-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 6px;
        }
        .badge-pending { background: rgba(255,152,0,0.15); color: var(--orange-800); }
        .badge-dev { background: rgba(156,39,176,0.12); color: var(--purple-700); }
        .badge-review { background: rgba(76,175,80,0.12); color: var(--green-800); }
        .badge-done { background: rgba(233,30,99,0.08); color: var(--pink-700); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(233,30,99,0.2); border-radius: 3px; }
        .list-item {
            background: var(--surface-list);
            backdrop-filter: blur(var(--glass-blur-list));
            -webkit-backdrop-filter: blur(var(--glass-blur-list));
            border: 1px solid var(--border-list);
            border-radius: var(--radius-card-sm);
            padding: 16px;
            margin-bottom: 12px;
            transition: transform var(--ease-smooth), box-shadow var(--ease-smooth);
        }
        .list-item:hover { transform: translateY(-1px); box-shadow: var(--shadow-list); }
        .flex { display: flex; }
        .flex-wrap { flex-wrap: wrap; }
        .flex-between { justify-content: space-between; }
        .flex-center { align-items: center; }
        .gap { gap: 10px; }
        .gap-sm { gap: 6px; }
        .text-sm { font-size: 13px; }
        .text-xs { font-size: 11px; }
        .text-muted { color: var(--text-muted); }
        .text-desc { color: var(--text-desc); }
        .mt-1 { margin-top: 4px; }
        .mt-2 { margin-top: 8px; }
        .mb-1 { margin-bottom: 4px; }
        .mb-2 { margin-bottom: 8px; }

        /* --- Toast System --- */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
            max-width: 380px;
            width: calc(100% - 40px);
        }
        .toast {
            pointer-events: auto;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 14px 18px;
            border-radius: var(--radius-btn);
            color: #fff;
            font-size: 14px;
            line-height: 1.5;
            box-shadow: 0 6px 24px rgba(0,0,0,0.18);
            animation: toastSlideIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
        }
        .toast-icon { font-size: 18px; flex-shrink: 0; line-height: 1.4; }
        .toast-msg { flex: 1; }
        .toast-close {
            flex-shrink: 0;
            background: none;
            border: none;
            color: rgba(255,255,255,0.7);
            cursor: pointer;
            font-size: 16px;
            padding: 0 0 0 4px;
            line-height: 1.4;
        }
        .toast-close:hover { color: #fff; }
        .toast-error { background: var(--toast-bg-error); }
        .toast-success { background: var(--toast-bg-success); }
        .toast-info { background: var(--toast-bg-info); }
        .toast-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: rgba(255,255,255,0.35);
            border-radius: 0 2px 0 0;
            animation: toastProgress 4s linear forwards;
        }
        .toast.paused .toast-progress {
            animation-play-state: paused;
        }
        @keyframes toastSlideIn {
            0% { transform: translateX(120%) scale(0.9); opacity: 0; }
            100% { transform: translateX(0) scale(1); opacity: 1; }
        }
        @keyframes toastSlideOut {
            0% { transform: translateX(0) scale(1); opacity: 1; }
            100% { transform: translateX(120%) scale(0.9); opacity: 0; }
        }
        @keyframes toastProgress {
            0% { width: 100%; }
            100% { width: 0%; }
        }

        /* --- Reduced Motion --- */
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
            .hearts { display: none !important; }
            .card:hover { transform: none; }
            .list-item:hover { transform: none; }
            .btn:hover { transform: none; }
            .toast { animation: none; }
        }

        @media (max-width: 640px) {
            .container { padding: 12px; }
            .card { padding: 16px; margin: 12px 0; border-radius: var(--radius-card-sm); }
            h1 { font-size: 22px; }
            .nav .container { padding: 10px 12px; }
            .nav .brand { font-size: 16px; }
            .nav-email { display: none; }
            .nav-toggle { display: block; }
            .nav .nav-links {
                display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0;
                background: rgba(255,255,255,0.96); backdrop-filter: blur(var(--glass-blur-nav));
                border-bottom: 1px solid var(--border-nav); padding: 12px 16px; gap: 10px; z-index: 200;
                box-shadow: var(--shadow-nav);
            }
            .nav .nav-links.open { display: flex; }
            .nav .nav-links a, .nav .nav-links form, .nav .nav-links .btn { width: 100%; }
            .nav .nav-links .btn { justify-content: center; margin: 0; }
            .nav .nav-links .nav-email-mobile { display: block; font-size: 12px; color: var(--text-muted); padding: 4px 0; border-bottom: 1px solid var(--border-subtle); margin-bottom: 4px; }
            .nav { position: relative; }
            table, thead, tbody, th, td, tr { display: block; }
            thead { display: none; }
            td { padding: 10px 12px; border: none; border-bottom: 1px solid rgba(233,30,99,0.06); }
            td:last-child { border-bottom: 2px solid rgba(233,30,99,0.1); }
            td:before { content: attr(data-label); display: block; font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 2px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .stat-card { padding: 12px; }
            .stat-card .num { font-size: 22px; }
            .tabs { overflow-x: auto; flex-wrap: nowrap; }
            .tab-btn { padding: 6px 12px; font-size: 13px; flex-shrink: 0; }
            .badge-count { min-width: 18px; height: 18px; font-size: 10px; padding: 0 4px; }
            .btn { padding: 12px 18px; font-size: 15px; min-height: 44px; }
            .btn-sm { padding: 10px 14px; font-size: 14px; min-height: 40px; }
            input, textarea, select { padding: 14px 12px; font-size: 16px; }
            .list-item { padding: 14px; }
            .list-item .flex-wrap form { width: 100%; }
            .hearts { display: none; }
            .toast-container { top: 12px; right: 12px; width: calc(100% - 24px); max-width: none; }
            .toast { padding: 12px 14px; font-size: 13px; }
        }
        @media (prefers-color-scheme: dark) and (max-width: 640px) {
            .nav .nav-links.open { background: rgba(30,12,20,0.96); }
        }
        .hearts {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .heart {
            position: absolute;
            bottom: -40px;
            animation: floatUp linear infinite;
            user-select: none;
        }
        @keyframes floatUp {
            0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0; }
            10% { opacity: 0.5; }
            90% { opacity: 0.3; }
            100% { transform: translateY(-110vh) rotate(720deg) scale(1.3); opacity: 0; }
        }
    </style>
</head>
<body>
    <div class="hearts" id="hearts"></div>
    <div class="nav">
        <div class="container">
            <a href="/" class="brand">Pier</a>
            <button class="nav-toggle" id="navToggle" aria-label="菜单">☰</button>
            <div class="nav-links" id="navLinks">
                <% if (typeof userId !== 'undefined' && userId) { %>
                    <a href="/profile" class="nav-email-mobile" style="display:none"><%= typeof userName !== 'undefined' && userName ? userName : (typeof userEmail !== 'undefined' ? userEmail : '') %></a>
                    <a href="/profile" class="nav-email"><%= typeof userName !== 'undefined' && userName ? userName : (typeof userEmail !== 'undefined' ? userEmail : '') %></a>
                    <a href="/dashboard">控制台</a>
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <a href="/admin/requests">管理后台</a>
                    <% } %>
                    <form method="POST" action="/auth/logout">
                        <button type="submit" class="btn btn-outline btn-sm">退出</button>
                    </form>
                <% } else { %>
                    <a href="/auth/login">登录</a>
                    <a href="/auth/register">注册</a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="container">
        <%- body %>
    </div>
    <div class="watermark">
        Pier · <%= typeof contactEmail !== 'undefined' && contactEmail ? '联系: ' + contactEmail + '（管理员可能无法及时查看）' : '' %>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <script>
    (function() {
        // Floating hearts
        var container = document.getElementById('hearts');
        if (container) {
            var emojis = ['💕', '💗', '💖', '💝', '❤️', '💓', '🩷', '♥️'];
            for (var i = 0; i < 35; i++) {
                var heart = document.createElement('div');
                heart.className = 'heart';
                heart.textContent = emojis[i % emojis.length];
                heart.style.left = Math.random() * 100 + '%';
                heart.style.animationDuration = (10 + Math.random() * 18) + 's';
                heart.style.animationDelay = (Math.random() * 20) + 's';
                var size = 16 + Math.random() * 22;
                heart.style.fontSize = size + 'px';
                container.appendChild(heart);
            }
        }

        // Nav toggle
        var toggle = document.getElementById('navToggle');
        var links = document.getElementById('navLinks');
        if (toggle && links) {
            toggle.addEventListener('click', function() { links.classList.toggle('open'); });
            document.addEventListener('click', function(e) {
                if (!toggle.contains(e.target) && !links.contains(e.target)) links.classList.remove('open');
            });
        }

        // Toast system
        var toastContainer = document.getElementById('toastContainer');

        window.showToast = function(message, type) {
            type = type || 'info';
            if (!toastContainer) return;
            var toast = document.createElement('div');
            toast.className = 'toast toast-' + type;
            var icons = { error: '✕', success: '✓', info: '●' };
            var icon = icons[type] || '●';
            toast.innerHTML =
                '<span class="toast-icon">' + icon + '</span>' +
                '<span class="toast-msg">' + escapeHtml(message) + '</span>' +
                '<button class="toast-close" onclick="dismissToast(this.parentElement)">✕</button>' +
                '<div class="toast-progress"></div>';
            toastContainer.appendChild(toast);
            toast.addEventListener('mouseenter', function() { toast.classList.add('paused'); });
            toast.addEventListener('mouseleave', function() { toast.classList.remove('paused'); });
            setTimeout(function() { dismissToast(toast); }, 4000);
        };

        window.dismissToast = function(toast) {
            if (!toast || toast.classList.contains('removing')) return;
            toast.classList.add('removing');
            toast.style.animation = 'toastSlideOut 0.3s ease-in forwards';
            setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 300);
        };

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        // Auto-detect data-toast elements
        document.querySelectorAll('[data-toast]').forEach(function(el) {
            var msg = el.getAttribute('data-toast');
            var type = el.getAttribute('data-toast-type') || 'error';
            if (msg && window.showToast) {
                setTimeout(function() { showToast(msg, type); }, 300);
            }
        });
    })();
    </script>
</body>
</html>