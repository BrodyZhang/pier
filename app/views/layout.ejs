<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Pier' %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, 'Microsoft YaHei', 'PingFang SC', sans-serif;
            background: linear-gradient(180deg, #fff0f5 0%, #ffe4ec 25%, #ffd6e0 50%, #ffe4ec 75%, #fff0f5 100%);
            min-height: 100vh;
            color: #4a4a6a;
        }
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; position: relative; }
        .card {
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,182,193,0.25);
            border-radius: 20px;
            padding: 28px;
            margin: 20px 0;
            box-shadow: 0 4px 24px rgba(233,30,99,0.06);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(233,30,99,0.12);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 12px 24px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all 0.25s;
            min-height: 44px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #ff6b9d, #c2185b);
            color: #fff;
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(255,107,157,0.4); }
        .btn-success {
            background: linear-gradient(135deg, #ff6b9d, #e91e63);
            color: #fff;
        }
        .btn-success:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(233,30,99,0.4); }
        .btn-danger {
            background: linear-gradient(135deg, #ff5252, #d32f2f);
            color: #fff;
        }
        .btn-danger:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(255,82,82,0.4); }
        .btn-outline {
            background: rgba(255,255,255,0.7);
            border: 1.5px solid rgba(233,30,99,0.2);
            color: #c2185b;
        }
        .btn-outline:hover { border-color: #ff6b9d; background: rgba(255,107,157,0.08); }
        .btn-sm { padding: 6px 16px; font-size: 13px; border-radius: 8px; }
        .error { color: #d32f2f; background: rgba(255,82,82,0.08); padding: 14px 18px; border-radius: 12px; margin: 12px 0; border-left: 3px solid #ff5252; }
        .success { color: #2e7d32; background: rgba(76,175,80,0.08); padding: 14px 18px; border-radius: 12px; margin: 12px 0; border-left: 3px solid #4caf50; }
        h1 { font-size: 26px; font-weight: 700; background: linear-gradient(135deg, #ff6b9d, #c2185b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        h2 { font-size: 18px; font-weight: 600; color: #5c5c7a; margin-bottom: 16px; }
        label { display: block; margin: 14px 0 6px; font-weight: 500; color: #6c6c8a; font-size: 14px; }
        input, textarea, select {
            width: 100%;
            padding: 14px 14px;
            background: rgba(255,255,255,0.8);
            border: 1.5px solid rgba(233,30,99,0.15);
            border-radius: 12px;
            font-size: 16px;
            color: #4a4a6a;
            transition: border-color 0.2s, box-shadow 0.2s;
            font-family: inherit;
        }
        input:focus, textarea:focus, select:focus { outline: none; border-color: #ff6b9d; box-shadow: 0 0 0 3px rgba(255,107,157,0.15); }
        textarea { resize: vertical; min-height: 100px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 14px 12px; border-bottom: 1px solid rgba(233,30,99,0.08); }
        th { font-weight: 600; color: #b0b0c8; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
        td { color: #5c5c7a; font-size: 14px; }
        tr:hover td { background: rgba(255,107,157,0.03); }
        .status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }
        .status-pending { background: rgba(255,152,0,0.12); color: #e65100; }
        .status-pending::before { background: #ff9800; }
        .status-dev { background: rgba(156,39,176,0.1); color: #7b1fa2; }
        .status-dev::before { background: #9c27b0; }
        .status-done { background: rgba(76,175,80,0.1); color: #2e7d32; }
        .status-done::before { background: #4caf50; }
        .status-rejected { background: rgba(244,67,54,0.1); color: #c62828; }
        .status-rejected::before { background: #f44336; }
        .nav {
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(233,30,99,0.08);
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
        }
        .nav .nav-links { display: flex; align-items: center; gap: 6px; }
            .nav-email { display: inline-block; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; color: #b0b0c8; }
        .nav a { color: #6c6c8a; text-decoration: none; font-size: 14px; transition: color 0.2s; }
        .nav a:hover { color: #ff6b9d; }
        .nav .brand { font-weight: 700; font-size: 18px; background: linear-gradient(135deg, #ff6b9d, #c2185b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-right: auto; }
        .nav form { display: inline; }
        .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 6px; color: #6c6c8a; font-size: 22px; }
        .watermark {
            position: fixed;
            bottom: 12px;
            right: 16px;
            font-size: 11px;
            color: rgba(233,30,99,0.08);
            z-index: 9999;
            pointer-events: none;
            letter-spacing: 0.5px;
        }
        .disclaimer {
            background: rgba(255,152,0,0.06);
            border: 1px solid rgba(255,152,0,0.15);
            padding: 12px 16px;
            border-radius: 12px;
            margin: 16px 0;
            font-size: 13px;
            color: #e65100;
        }
        code {
            background: rgba(255,107,157,0.08);
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 13px;
            color: #c2185b;
        }
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #b0b0c8;
        }
        .empty-state p { font-size: 15px; margin-top: 8px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: rgba(255,255,255,0.7);
            border: 1px solid rgba(233,30,99,0.08);
            border-radius: 14px;
            padding: 16px;
            text-align: center;
        }
        .stat-card .num { font-size: 28px; font-weight: 700; }
        .stat-card .label { font-size: 12px; color: #b0b0c8; margin-top: 4px; }
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 0;
            background: rgba(255,255,255,0.6);
            border-radius: 14px;
            padding: 4px;
            overflow-x: auto;
        }
        .tab-btn {
            padding: 8px 18px;
            border: none;
            background: transparent;
            color: #b0b0c8;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: all 0.2s;
        }
        .tab-btn:hover { color: #6c6c8a; }
        .tab-btn.active { background: rgba(255,107,157,0.15); color: #c2185b; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .badge-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 6px;
        }
        .badge-pending { background: rgba(255,152,0,0.15); color: #e65100; }
        .badge-dev { background: rgba(156,39,176,0.12); color: #7b1fa2; }
        .badge-review { background: rgba(76,175,80,0.12); color: #2e7d32; }
        .badge-done { background: rgba(233,30,99,0.08); color: #c2185b; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(233,30,99,0.2); border-radius: 3px; }
        .list-item {
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255,182,193,0.2);
            border-radius: 14px;
            padding: 16px;
            margin-bottom: 12px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .list-item:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(233,30,99,0.08); }
        .flex { display: flex; }
        .flex-wrap { flex-wrap: wrap; }
        .flex-between { justify-content: space-between; }
        .flex-center { align-items: center; }
        .gap { gap: 10px; }
        .gap-sm { gap: 6px; }
        .text-sm { font-size: 13px; }
        .text-xs { font-size: 11px; }
        .text-muted { color: #b0b0c8; }
        .text-desc { color: #8c8caa; }
        .mt-1 { margin-top: 4px; }
        .mt-2 { margin-top: 8px; }
        .mb-1 { margin-bottom: 4px; }
        .mb-2 { margin-bottom: 8px; }
        @media (max-width: 640px) {
            .container { padding: 12px; }
            .card { padding: 16px; margin: 12px 0; border-radius: 14px; }
            h1 { font-size: 22px; }
            .nav .container { padding: 10px 12px; }
            .nav .brand { font-size: 16px; }
            .nav-email { display: none; }
            .nav-toggle { display: block; }
            .nav .nav-links {
                display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0;
                background: rgba(255,255,255,0.96); backdrop-filter: blur(20px);
                border-bottom: 1px solid rgba(233,30,99,0.08); padding: 12px 16px; gap: 10px; z-index: 200;
                box-shadow: 0 8px 24px rgba(0,0,0,0.06);
            }
            .nav .nav-links.open { display: flex; }
            .nav .nav-links a, .nav .nav-links form, .nav .nav-links .btn { width: 100%; }
            .nav .nav-links .btn { justify-content: center; margin: 0; }
            .nav .nav-links .nav-email-mobile { display: block; font-size: 12px; color: #b0b0c8; padding: 4px 0; border-bottom: 1px solid rgba(233,30,99,0.08); margin-bottom: 4px; }
            .nav { position: relative; }
            table, thead, tbody, th, td, tr { display: block; }
            thead { display: none; }
            td { padding: 10px 12px; border: none; border-bottom: 1px solid rgba(233,30,99,0.06); }
            td:last-child { border-bottom: 2px solid rgba(233,30,99,0.1); }
            td:before { content: attr(data-label); display: block; font-size: 11px; color: #b0b0c8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 2px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
            .stat-card { padding: 12px; }
            .stat-card .num { font-size: 22px; }
            .tabs { overflow-x: auto; flex-wrap: nowrap; }
            .tab-btn { padding: 6px 12px; font-size: 13px; flex-shrink: 0; }
            .badge-count { min-width: 18px; height: 18px; font-size: 10px; padding: 0 4px; }
            .btn { padding: 12px 18px; font-size: 15px; min-height: 44px; }
            .btn-sm { padding: 10px 14px; font-size: 14px; min-height: 40px; }
            input, textarea, select { padding: 14px 12px; font-size: 16px; }
            .list-item { padding: 14px; }
            .list-item .flex-wrap form { width: 100%; }
            .hearts { display: none; }
        }
        .hearts {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .heart {
            position: absolute;
            bottom: -40px;
            animation: floatUp linear infinite;
            user-select: none;
        }
        @keyframes floatUp {
            0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0; }
            10% { opacity: 0.5; }
            90% { opacity: 0.3; }
            100% { transform: translateY(-110vh) rotate(720deg) scale(1.3); opacity: 0; }
        }
    </style>
</head>
<body>
    <div class="hearts" id="hearts"></div>
    <div class="nav">
        <div class="container">
            <a href="/" class="brand">Pier</a>
            <button class="nav-toggle" id="navToggle" aria-label="菜单">☰</button>
            <div class="nav-links" id="navLinks">
                <% if (typeof userId !== 'undefined' && userId) { %>
                    <span class="nav-email-mobile"><%= typeof userEmail !== 'undefined' ? userEmail : '' %></span>
                    <span class="nav-email"><%= typeof userEmail !== 'undefined' ? userEmail : '' %></span>
                    <a href="/dashboard">控制台</a>
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <a href="/admin/requests">管理后台</a>
                    <% } %>
                    <form method="POST" action="/auth/logout">
                        <button type="submit" class="btn btn-outline btn-sm">退出</button>
                    </form>
                <% } else { %>
                    <a href="/auth/login">登录</a>
                    <a href="/auth/register">注册</a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="container">
        <%- body %>
    </div>
    <div class="watermark">
        Pier · <%= typeof adminEmail !== 'undefined' && adminEmail ? '联系: ' + adminEmail + '（管理员可能无法及时查看）' : '' %>
    </div>
    <script>
    (function() {
        var container = document.getElementById('hearts');
        var emojis = ['💕', '💗', '💖', '💝', '❤️', '💓', '🩷', '♥️'];
        for (var i = 0; i < 35; i++) {
            var heart = document.createElement('div');
            heart.className = 'heart';
            heart.textContent = emojis[i % emojis.length];
            heart.style.left = Math.random() * 100 + '%';
            heart.style.animationDuration = (10 + Math.random() * 18) + 's';
            heart.style.animationDelay = (Math.random() * 20) + 's';
            var size = 16 + Math.random() * 22;
            heart.style.fontSize = size + 'px';
            container.appendChild(heart);
        }
        // Nav toggle
        var toggle = document.getElementById('navToggle');
        var links = document.getElementById('navLinks');
        if (toggle && links) {
            toggle.addEventListener('click', function() { links.classList.toggle('open'); });
            document.addEventListener('click', function(e) {
                if (!toggle.contains(e.target) && !links.contains(e.target)) links.classList.remove('open');
            });
        }
    })();
    </script>
</body>
</html>