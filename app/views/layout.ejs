<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Pier' %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, 'Microsoft YaHei', 'PingFang SC', sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            color: #e0e0e0;
        }
        .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
        .card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 28px;
            margin: 20px 0;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 24px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all 0.25s;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
        }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(102,126,234,0.4); }
        .btn-success {
            background: linear-gradient(135deg, #11998e, #38ef7d);
            color: #fff;
        }
        .btn-success:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(17,153,142,0.4); }
        .btn-danger {
            background: linear-gradient(135deg, #eb3349, #f45c43);
            color: #fff;
        }
        .btn-danger:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(235,51,73,0.4); }
        .btn-outline {
            background: transparent;
            border: 1.5px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.8);
        }
        .btn-outline:hover { border-color: #667eea; color: #667eea; }
        .btn-sm { padding: 6px 16px; font-size: 13px; border-radius: 8px; }
        .error { color: #ff6b6b; background: rgba(235,51,73,0.15); padding: 14px 18px; border-radius: 10px; margin: 12px 0; border-left: 3px solid #eb3349; }
        .success { color: #38ef7d; background: rgba(17,153,142,0.15); padding: 14px 18px; border-radius: 10px; margin: 12px 0; border-left: 3px solid #11998e; }
        h1 { font-size: 26px; font-weight: 700; background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        h2 { font-size: 18px; font-weight: 600; color: rgba(255,255,255,0.9); margin-bottom: 16px; }
        label { display: block; margin: 14px 0 6px; font-weight: 500; color: rgba(255,255,255,0.7); font-size: 14px; }
        input, textarea, select {
            width: 100%;
            padding: 12px 14px;
            background: rgba(255,255,255,0.08);
            border: 1.5px solid rgba(255,255,255,0.12);
            border-radius: 10px;
            font-size: 15px;
            color: #e0e0e0;
            transition: border-color 0.2s, box-shadow 0.2s;
            font-family: inherit;
        }
        input:focus, textarea:focus, select:focus { outline: none; border-color: #667eea; box-shadow: 0 0 0 3px rgba(102,126,234,0.2); }
        textarea { resize: vertical; min-height: 80px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 14px 12px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        th { font-weight: 600; color: rgba(255,255,255,0.5); font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; }
        td { color: rgba(255,255,255,0.85); font-size: 14px; }
        tr:hover td { background: rgba(255,255,255,0.03); }
        .status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .status::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }
        .status-pending { background: rgba(255,193,7,0.15); color: #ffc107; }
        .status-pending::before { background: #ffc107; }
        .status-dev { background: rgba(102,126,234,0.15); color: #667eea; }
        .status-dev::before { background: #667eea; }
        .status-done { background: rgba(56,239,125,0.15); color: #38ef7d; }
        .status-done::before { background: #38ef7d; }
        .status-rejected { background: rgba(235,51,73,0.15); color: #ff6b6b; }
        .status-rejected::before { background: #ff6b6b; }
        .nav {
            background: rgba(15,12,41,0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
        }
        .nav a { color: rgba(255,255,255,0.75); text-decoration: none; margin-left: 20px; font-size: 14px; transition: color 0.2s; }
        .nav a:hover { color: #667eea; }
        .nav .brand { font-weight: 700; font-size: 18px; color: #fff; }
        .nav form { display: inline; }
        .watermark {
            position: fixed;
            bottom: 12px;
            right: 16px;
            font-size: 11px;
            color: rgba(255,255,255,0.1);
            z-index: 9999;
            pointer-events: none;
            letter-spacing: 0.5px;
        }
        .disclaimer {
            background: rgba(255,193,7,0.1);
            border: 1px solid rgba(255,193,7,0.2);
            padding: 12px 16px;
            border-radius: 10px;
            margin: 16px 0;
            font-size: 13px;
            color: #ffc107;
        }
        code {
            background: rgba(255,255,255,0.08);
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 13px;
            color: #38ef7d;
        }
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: rgba(255,255,255,0.4);
        }
        .empty-state p { font-size: 15px; margin-top: 8px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }
        .stat-card {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
        }
        .stat-card .num { font-size: 28px; font-weight: 700; }
        .stat-card .label { font-size: 12px; color: rgba(255,255,255,0.5); margin-top: 4px; }
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 0;
            background: rgba(255,255,255,0.04);
            border-radius: 12px;
            padding: 4px;
            overflow-x: auto;
        }
        .tab-btn {
            padding: 8px 18px;
            border: none;
            background: transparent;
            color: rgba(255,255,255,0.5);
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: all 0.2s;
        }
        .tab-btn:hover { color: rgba(255,255,255,0.8); }
        .tab-btn.active { background: rgba(102,126,234,0.3); color: #667eea; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .inline-form { display: inline-flex; align-items: center; gap: 6px; }
        .inline-form textarea {
            width: auto;
            min-width: 140px;
            padding: 6px 10px;
            font-size: 13px;
            min-height: 32px;
        }
        .badge-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            margin-left: 6px;
        }
        .badge-pending { background: rgba(255,193,7,0.2); color: #ffc107; }
        .badge-dev { background: rgba(102,126,234,0.2); color: #667eea; }
        .badge-review { background: rgba(56,239,125,0.2); color: #38ef7d; }
        .badge-done { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 3px; }
    </style>
</head>
<body>
    <div class="nav">
        <div class="container">
            <a href="/" class="brand">Pier</a>
            <div>
                <% if (typeof userId !== 'undefined' && userId) { %>
                    <span style="font-size:13px;color:rgba(255,255,255,0.5);margin-right:8px;"><%= typeof userEmail !== 'undefined' ? userEmail : '' %></span>
                    <a href="/dashboard">控制台</a>
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <a href="/admin/requests">管理后台</a>
                    <% } %>
                    <form method="POST" action="/auth/logout" style="display:inline;">
                        <button type="submit" class="btn btn-outline btn-sm" style="margin-left:10px;">退出</button>
                    </form>
                <% } else { %>
                    <a href="/auth/login">登录</a>
                    <a href="/auth/register">注册</a>
                <% } %>
            </div>
        </div>
    </div>
    <div class="container">
        <%- body %>
    </div>
    <div class="watermark">AI automated</div>
</body>
</html>
