<style>
.dash-actions { display:flex; flex-wrap:wrap; align-items:center; gap:6px; }
.dash-form { display:inline; }
.btn-dash { padding:10px 16px; border-radius:10px; cursor:pointer; font-size:14px; text-decoration:none; display:inline-flex; align-items:center; gap:6px; border:1px solid rgba(233,30,99,0.15); justify-content:center; min-height:42px; }
.btn-dash-view { background:rgba(255,255,255,0.7); color:#c2185b; }
.btn-dash-share { background:linear-gradient(135deg,#ff6b9d,#c2185b); color:#fff; border:none; }
.btn-dash-version { background:rgba(156,39,176,0.1); color:#9c27b0; border:1px solid rgba(156,39,176,0.2); }
.btn-dash-delete { background:rgba(233,30,99,0.08); color:#c2185b; }
/* Mobile-first: cards instead of table rows */
@media (max-width:768px) {
    .btn-dash { padding:12px 14px; font-size:14px; min-height:44px; }
    .dash-actions { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
    .dash-actions a, .dash-actions form { width:100%; }
    .dash-form { width:100%; }
    .btn-dash { width:100%; }
}
.dash-row { background:rgba(255,255,255,0.8); border:1px solid rgba(233,30,99,0.1); border-radius:14px; margin-bottom:12px; padding:14px; box-shadow:0 2px 8px rgba(233,30,99,0.04); }
.dash-row-info { display:flex; flex-wrap:wrap; align-items:center; gap:8px; margin-bottom:8px; }
@media (min-width:769px) {
    .dash-row { display:table-row; background:none; border:none; border-radius:0; padding:0; margin:0; box-shadow:none; }
    .dash-row td { padding:14px 12px; border-bottom:1px solid rgba(233,30,99,0.08); }
}
</style>
<div class="card">
    <div class="flex flex-wrap flex-between flex-center gap">
        <h1>控制台</h1>
        <a href="/agent/new" class="btn btn-primary">新建请求</a>
    </div>
</div>

<div class="card">
    <h2>我的请求</h2>
    <% if (agents.length === 0) { %>
        <div class="empty-state">
            <div style="font-size:40px;margin-bottom:8px;">💕</div>
            <p>还没有请求。<a href="/agent/new" style="color:#e91e63;text-decoration:none;">创建第一个吧！</a></p>
        </div>
    <% } else { %>
        <div style="overflow-x:auto;">
            <table>
                <thead><tr><th>信息</th><th></th></tr></thead>
                <% agents.forEach(function(a) { %>
                    <tr class="dash-row">
                        <td data-label="信息"><strong><%= a.name %></strong>
                            <span class="dash-row-info">
                                <span class="status status-<%= a.status === 'pending_review' ? 'pending' : a.status === 'in_development' || a.status === 'dev_review' ? 'dev' : a.status === 'completed' ? 'done' : 'rejected' %>">
                                    <% if (a.status === 'pending_review') { %>待审核<% } else if (a.status === 'in_development' || a.status === 'dev_review') { %>开发中<% } else if (a.status === 'completed') { %>已完成<% } else { %>已拒绝<% } %>
                                </span>
                                <% if (a.version_number > 1) { %><span style="background:rgba(156,39,176,0.1);color:#9c27b0;padding:1px 6px;border-radius:3px;font-size:11px;">v<%= a.version_number %></span><% } %>
                                <% if (a.parent_id) { %><span style="color:#b0b0c8;font-size:11px;">基于 v<%= a.version_number - 1 %></span><% } else { %><span style="color:#b0b0c8;font-size:11px;">v1</span><% } %>
                                <span style="color:#b0b0c8;font-size:11px;"><%= new Date(a.created_at).toLocaleDateString() %></span>
                            </span>
                        </td>
                        <td data-label="操作">
                            <div class="dash-actions">
                                <% if ((a.status === 'completed' || a.status === 'dev_review') && a.unique_slug) { %>
                                    <a href="/agent/<%= a.unique_slug %>" class="btn-dash btn-dash-view">查看</a>
                                <% } %>
                                <% if (a.status === 'completed') { %>
                                    <a href="/agent/<%= a.unique_slug %>/share" class="btn-dash btn-dash-share">分享</a>
                                    <a href="/agent/<%= a.id %>/request-version" class="btn-dash btn-dash-version">新版</a>
                                <% } %>
                                <% if (a.status === 'rejected' && a.rejection_reason) { %>
                                    <span class="text-sm" style="color:#d32f2f;padding:4px 0;"><%= a.rejection_reason %></span>
                                <% } %>
                                <form method="POST" action="/agent/<%= a.id %>/delete" class="dash-form" onsubmit="return confirm('确定删除「<%= a.name %>」？此操作不可恢复。');">
                                    <button type="submit" class="btn-dash btn-dash-delete">删除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </table>
        </div>
    <% } %>
</div>

<% if (sharedAgents.length > 0) { %>
<div class="card">
    <h2>分享给我的</h2>
    <div style="overflow-x:auto;">
        <table>
            <tr><th>名称</th><th>创建者</th><th></th></tr>
            <% sharedAgents.forEach(function(a) { %>
                <tr>
                    <td data-label="名称"><strong><%= a.name %></strong></td>
                    <td data-label="创建者" style="color:#6c6c8a;"><%= a.creator_email %></td>
                    <td data-label="操作">
                        <% if (a.unique_slug) { %>
                            <a href="/agent/<%= a.unique_slug %>" class="btn btn-outline btn-sm">查看</a>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</div>
<% } %>
